{
  "name": "sachsen",
  "version": "1.0.0",
  "license": "MIT",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "dev:web": "turbo run dev --filter=@repo/web-frontend",
    "dev:app": "turbo run dev --filter=@repo/app",
    "dev:api": "turbo run dev --filter=@repo/api",
    "dev": "turbo run dev --filter=@repo/api --filter=@repo/app"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:^",
    "prettier": "^3.8.1",
    "turbo": "^2.8.7",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "yarn@4.12.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
